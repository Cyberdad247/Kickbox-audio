# Kickbox-audio environment template
# Copy to `.env.local` for local dev. NEVER commit `.env.local` (gitignored).
# In Vercel, set these in Project Settings > Environment Variables.

## === Database (Prisma) ===
# Local dev: docker run -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres
DATABASE_URL=postgresql://user:password@localhost:5432/kickbox?schema=public

## === Bifrost gateway (HMAC envelope) ===
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-32-bytes-hex
ACTION_SECRET=change-me-32-bytes-hex

## === Bifrost rate limits (v1.1.0 externalized) ===
# Issue action rate limit (requests per windowMs)
ISSUE_RATE_LIMIT_MAX=30
ISSUE_RATE_LIMIT_WINDOW_MS=60000
# HITL (Human-in-the-loop) rate limit
HITL_RATE_LIMIT_MAX=60
HITL_RATE_LIMIT_WINDOW_MS=60000

## === Bifrost server ===
PORT=3017
HOST=http://localhost
ACTION_ID=KBA_SYNC_001

## === PWA (Next.js) ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BIFROST_WS_URL=ws://localhost:3017

## === Observability (v1.1.0+) ===
# Pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
# Optional: Sentry DSN for error tracking (v1.2.0 candidate)
# SENTRY_DSN=

## === Feature flags ===
# 0 = off, 1 = on
FEATURE_KINETIC_CANVAS=1
FEATURE_VOICE_HUD=1
