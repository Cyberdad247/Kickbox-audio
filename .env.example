# Kickbox-audio environment template
# Copy to `.env.local` for local dev. NEVER commit `.env.local` (gitignored).
# In Vercel, set these in Project Settings > Environment Variables.

## === Database (Prisma) ===
# Local dev: docker run -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres
DATABASE_URL=postgresql://user:password@localhost:5432/kickbox?schema=public

## === Bifrost gateway (HMAC envelope) ===
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-32-bytes-hex
ACTION_SECRET=change-me-32-bytes-hex

## === Bifrost rate limits (v1.1.0 externalized) ===
# Issue action rate limit (requests per windowMs)
ISSUE_RATE_LIMIT_MAX=30
ISSUE_RATE_LIMIT_WINDOW_MS=60000
# HITL (Human-in-the-loop) rate limit
HITL_RATE_LIMIT_MAX=60
HITL_RATE_LIMIT_WINDOW_MS=60000

## === Bifrost server ===
PORT=3017
HOST=http://localhost
ACTION_ID=KBA_SYNC_001

## === PWA (Next.js) ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BIFROST_WS_URL=ws://localhost:3017

## === Observability (v1.1.0+) ===
# Pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

## === Sentry (v1.2.0 T3.2+v1.3.0 Tier 3.2) ===
# Get yours at https://sentry.io/signup/ — create a project for each
# environment (pwa-node, bifrost-node). Empty DSN disables Sentry.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

## === Sentry replay-coverage telemetry (v1.3.0 Tier 3.2) ===
# Sentry auth token used by apps/pwa/src/app/api/diagnostics/replay-coverage
# to query the Sentry replay-stats sub-endpoint. Required only if you
# want to scrape sessionCount / errorCaptureRate / p75ReplayBytes from
# /api/diagnostics/replay-coverage via curl with ADMIN_TOKEN. The vault
# key pwa/sentry-auth-token is the Doppler-stored equivalent.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=kickbox-audio
# SENTRY_PROJECT=pwa

## === Upstash Redis (v1.4.0, multi-region rate-limit) ===
# REST URL + token for Upstash Redis. Used by apps/pwa/src/lib/rateLimit.ts
# to back the /api/diagnostics/replay-coverage rate limit so the 60 req /
# IP / 60 s ceiling is shared across all Vercel edge regions. When unset,
# the helper falls back to an in-memory Map (single-instance; console.warn
# on each call). Provisioning drill: PRODUCTION_RUNBOOK §6.8. Vault keys
# (Doppler): pwa/upstash-redis-rest-url + pwa/upstash-redis-rest-token.
# Free tier: 10K commands/day. The 1000 req / IP / 24 h hard-circuit
# (in the helper) keeps a single runaway scrape loop from exhausting it.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

## === OpenTelemetry (v1.2.0 T3.3) ===
# Set to your managed OTel collector endpoint (Honeycomb, Datadog, etc.).
# Empty disables tracing. The Bifrost gateway auto-instruments Express,
# http, and ws; the PWA browser SDK captures fetch + WebSocket traces.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=kickbox-bifrost
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=kickbox,service.version=1.2.0

## === Secrets vault (v1.2.0 T3.4) ===
# Doppler is the recommended vault (https://doppler.com). Generate a
# service token at https://dashboard.doppler.com/workplace/tokens.
# Empty DOPPLER_TOKEN falls back to reading secrets directly from env.
# DOPPLER_TOKEN=
# DOPPLER_PROJECT=kickbox-audio
# DOPPLER_CONFIG=dev
# WEBHOOK_SECRET_VAULT_KEY=bifrost/webhook-secret
# ACTION_SECRET_VAULT_KEY=bifrost/action-secret
# Bifrost reads cert revocation seed from CERT_REVOKED_LIST (comma-
# separated `serial:abc;by:alice;reason:compromised` entries). The hot
# store is in-memory; see PRODUCTION_RUNBOOK §6.5 for the live rotation
# workflow via /api/bifrost/admin/cert/revoke (+ /reissue).
# CERT_REVOKED_LIST=

## === Admin endpoints (v1.3.0 Tier 4.3) ===
# Bearer token required for POST /api/bifrost/admin/cert/{revoke,reissue}
# and GET /api/bifrost/admin/cert/revocations. Store in Doppler (vault
# key bifrost/admin-token) or set here for dev. Length >= 32 hex chars
# recommended; treat as a tier-1 secret.
# ADMIN_TOKEN=

## === mTLS (v1.2.0 T3.5) ===
# Certs generated by scripts/ops/generate-mtls-certs.sh. Required for
# the Tailscale MCP guard at apps/mcp-query. If MTLS_ENABLED=false, both
# sides fall back to plaintext over Tailscale (Tailscale mesh is the
# transport-level encryption).
# MTLS_ENABLED=false
# MTLS_CA_CERT_PATH=./certs/ca.pem
# MTLS_SERVER_CERT_PATH=./certs/server.pem
# MTLS_SERVER_KEY_PATH=./certs/server-key.pem
# MTLS_REQUIRE_CLIENT_CERT=true

## === RBAC (v1.2.0 T3.6 + v1.3.0 Tier 4.1) ===
# RBAC_ENABLED=true
# RBAC_ADMIN_ROLES=admin
# RBAC_OPERATOR_ROLES=operator,admin
# RBAC_VIEWER_ROLES=viewer,operator,admin

## === RBAC JWT algorithm (v1.3.0 Tier 4.1) ===
# Algorithm selector: HS256 (default, legacy shared secret) or RS256
# (asymmetric, OIDC-style, vault-stored public key). Strict env check
# prevents the classic alg-confusion downgrade attack — never auto-
# detect from the JWT header.
# RBAC_JWT_ALGORITHM=HS256

# HS256: WEBHOOK_SECRET is reused as the symmetric secret. To rotate,
# see PRODUCTION_RUNBOOK §6.1 (Doppler vault re-roll + pm2 restart).
# Rotation cadence: 90 days, or immediately on suspected compromise.

## === RBAC RS256 public key (v1.3.0 Tier 4.1) ===
# PEM SPKI format. The PRIVATE key never touches Bifrost — Bifrost is
# a Resource Server (verifier), not an IdP. Issuance lives in an
# external OIDC IdP (Auth0, Clerk, Cognito, etc.).
#
# Generation procedure (run ONCE out-of-band per PRODUCTION_RUNBOOK §6.2):
#   openssl genpkey -algorithm RSA -out /tmp/rbac-private.pem \
#     -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in /tmp/rbac-private.pem -pubout -out /tmp/rbac-public.pem
#   cat /tmp/rbac-public.pem   # paste contents (including BEGIN/END lines) below
#
# Storage: dopeR vault key bifrost/rbac-public-key-pem (recommended) OR
# this env var (dev/CI fallback).
# RBAC_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA....\n-----END PUBLIC KEY-----\n

## === RBAC OIDC claim validation (v1.3.0 Tier 4.1, optional) ===
# Both must be set together when used. Validates that the iss claim
# matches RBAC_OIDC_ISSUER and the aud claim matches RBAC_OIDC_AUDIENCE.
# RBAC_OIDC_ISSUER=https://idp.example.com
# RBAC_OIDC_AUDIENCE=bifrost-gateway

# Rotation cadence for the RSA keypair: every 90 days, or on suspected
# compromise. Single-key mode (current); kid-based multi-key rotation
# is a v1.4.0 candidate (see THREAT_MODEL §5 row 3).

## === Bundle-size budget (v1.2.0 T3.1) ===
# Per-route ceiling for PWA chunks. CI fails if exceeded.
# BUNDLE_SIZE_BUDGET_BYTES=153600

## === Feature flags ===
# 0 = off, 1 = on
FEATURE_KINETIC_CANVAS=1
FEATURE_VOICE_HUD=1
