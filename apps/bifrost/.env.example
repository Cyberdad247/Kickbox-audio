# Bifrost gateway configuration.
PORT=3001

# Shared secret for verifying inbound SMS/webhook HMAC-SHA256 signatures
# (header: x-webhook-signature). Set this to the secret configured at your
# telecom provider (Telnyx / Bandwidth).
WEBHOOK_SECRET=change-me

# Prisma database connection (used by @sovereign/db).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sovereign?schema=public&connection_limit=5"
