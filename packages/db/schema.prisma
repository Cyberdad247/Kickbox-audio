datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Transaction {
  id        String   @id @default(uuid())
  debit     Float
  credit    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EchoLog {
  id        String   @id @default(uuid())
  message   String
  timestamp DateTime @default(now())
}
