{
  "name": "@sovereign/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "prisma": {
    "schema": "schema.prisma",
    "seed": "tsx src/seed.ts"
  },
  "scripts": {
    "generate": "prisma generate --schema=schema.prisma",
    "migrate": "prisma migrate deploy --schema=schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=schema.prisma",
    "seed": "tsx src/seed.ts",
    "studio": "prisma studio --schema=schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  }
}
